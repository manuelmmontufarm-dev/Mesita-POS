{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npx prisma generate",
  "redirects": [
    { "source": "/", "destination": "/index.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/sistema/:path*", "destination": "/api" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  }
}
